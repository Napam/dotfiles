{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/mimo-v2.5",
  "default_agent": "orchestrator",

  // Inherited by all agents unless overridden. Agent permission blocks merge additively
  // on top — specify only the delta (e.g., orchestrator adds "task").
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
    },
    "external_directory": {
      "~/.go/**": "allow",
      "~/.cargo/**": "allow",
      "~/.gradle/**": "allow",
      "~/.m2/**": "allow",
      "~/.terraform.d/**": "allow",
      "~/.pub-cache/**": "allow",
      "~/.local/**": "allow",
      "~/.config/**": "allow",
      "/tmp": "allow",
    },
    "webfetch": "allow",
  },

  "agent": {
    // orchestrator, med, deep defined in agents/*.md (auto-discovered)
    // Pro model for hands-on coding without Orchestrator delegation overhead
    "build": {
      "model": "opencode-go/mimo-v2.5-pro",
    },

    "general": {
      "model": "opencode-go/mimo-v2.5-pro",
    },
  },

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1",
      },
      "models": {
        "gemma4:26b": { "name": "Gemma 4 26B" },
        "qwen3.6:latest": { "name": "Qwen 3.6" },
      },
    },
  },
}
