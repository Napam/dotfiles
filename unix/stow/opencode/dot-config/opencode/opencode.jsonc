{
  "$schema": "https://opencode.ai/config.json",
  // Default model for primary agents that don't override (i.e. Build)
  "model": "opencode/deepseek-v4-flash-free",
  // Small model for lightweight background tasks (title generation, etc.)
  "small_model": "opencode/deepseek-v4-flash-free",
  // The Orchestrator is the default landing agent
  "default_agent": "orchestrator",
  "agent": {
    // ─── Orchestrator ────────────────────────────────────────────────────────
    // Fast router. Does recon, answers simple questions, and delegates
    // coding tasks to @med or @deep with rich hand-off context.
    "orchestrator": {
      "description": "Fast routing agent. Gathers context, answers simple questions, delegates coding tasks to @med or @deep.",
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "prompt": "{file:./prompts/orchestrator.md}",
      "color": "#4ecdc4",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": {
          "*": "allow",
          "**/.env": "deny",
          "**/.env.*": "deny"
        },
        "external_directory": {
          "~/.go/**": "allow",
          "~/.cargo/**": "allow",
          "~/.gradle/**": "allow",
          "~/.m2/**": "allow",
          "~/.terraform.d/**": "allow",
          "~/.pub-cache/**": "allow",
          "~/.local/**": "allow"
        },
        "task": {
          "*": "allow", // Can delegate to any subagent...
          "general": "deny" // ...except general (Orchestrator fills this role)
        },
        "webfetch": "allow"
      }
    },
    // ─── Build (Tier 1 primary) ───────────────────────────────────────────────
    // Sonnet-powered direct coding agent. Tab to this for hands-on work
    // without the Orchestrator delegation overhead.
    "build": {
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": {
          "*": "allow",
          "**/.env": "deny",
          "**/.env.*": "deny"
        },
        "external_directory": {
          "~/.go/**": "allow",
          "~/.cargo/**": "allow",
          "~/.gradle/**": "allow",
          "~/.m2/**": "allow",
          "~/.terraform.d/**": "allow",
          "~/.pub-cache/**": "allow",
          "~/.local/**": "allow"
        },
        "webfetch": "allow"
      }
    },
    // ─── Built-in subagents ───────────────────────────────────────────────────
    // Note: med and deep subagents are defined in agents/*.md
    // (auto-discovered by OpenCode from the agents/ directory).
    "general": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    // ─── Janitor tier ─────────────────────────────────────────────────────────
    // Small model handles all background housekeeping tasks.
    "compaction": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "title": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "summary": {
      "model": "opencode/deepseek-v4-flash-free"
    }
  },
  // ─── Ollama (local models) ──────────────────────────────────────────────
  // Ollama runs an OpenAI-compatible API at localhost:11434/v1
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:26b": { "name": "Gemma 4 26B" },
        "qwen3.6:latest": { "name": "Qwen 3.6" }
      }
    }
  }
}
