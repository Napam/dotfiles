{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/mimo-v2.5",
  "default_agent": "orchestrator",

  // Inherited by all agents unless overridden. Agent permission blocks merge additively
  // on top — specify only the delta (e.g., orchestrator adds "task").
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
    },
    "external_directory": {
      "~/.go/**": "allow",
      "~/.cargo/**": "allow",
      "~/.gradle/**": "allow",
      "~/.m2/**": "allow",
      "~/.terraform.d/**": "allow",
      "~/.pub-cache/**": "allow",
      "~/.local/**": "allow",
      "~/.config/**": "allow",
      "~/.claude/**": "allow",
      "/tmp/**": "allow",
    },
    "webfetch": "allow",
  },

  "agent": {
    // Prompts/descriptions in agents/*.md; models defined here (avoids precedence bug with OPENCODE_CONFIG)
    "orchestrator": { "model": "opencode-go/mimo-v2.5", "variant": "high" },
    "low": { "model": "opencode-go/mimo-v2.5", "variant": "low" },
    "med": { "model": "opencode-go/mimo-v2.5-pro", "variant": "high" },
    "deep": { "model": "opencode-go/glm-5.2", "variant": "high" },
    "build": { "model": "opencode-go/mimo-v2.5-pro" },
    "general": { "model": "opencode-go/mimo-v2.5-pro" },
    "min": {
      "model": "llama-cpp-local/primary",
      "steps": 8,
      "permission": {
        "task": { "*": "deny" },
        "skill": { "*": "deny" },
        "webfetch": "deny",
        "todowrite": "deny",
        "question": "deny",
      },
    },
  },

  "plugin": ["opencode-with-claude@latest", "openslimedit@latest"],

  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "http://127.0.0.1:3456",
        "apiKey": "dummy",
      },
    },

    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "local-ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1",
      },
      "models": {
        "primary": { "name": "Local Ollama" },
      },
    },

    "llama-cpp-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "local-llama",
      "options": {
        "baseURL": "http://127.0.0.1:6700",
      },
      "models": {
        "primary": {
          "name": "Local LLama",
        },
      },
    },
  },
}
