{
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "NotebookEdit",
      "Read",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm -rf /)",
      "Bash(sudo rm -rf /*)",
      "Bash(rm -fr /)",
      "Bash(rm -fr /*)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$HOME/.claude/hooks/block-destructive.py\"; [ -f \"$f\" ] || exit 0; python3 \"$f\" 2>/dev/null || /usr/bin/python3 \"$f\" 2>/dev/null || exit 0",
            "statusMessage": "Screening for destructive commands"
          }
        ]
      }
    ]
  }
}
